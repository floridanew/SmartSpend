<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1E3A5F">

    <!-- Logo de l'application (animation fade-in gérée dans SplashActivity) -->
    <ImageView
        android:id="@+id/imageLogo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/logo_smartspend"
        android:contentDescription="Logo SmartSpend"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SmartSpend"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Gérez votre budget intelligemment"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

</LinearLayout>
