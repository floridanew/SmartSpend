<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textViewWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenue !"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1E3A5F" />

        <!-- Solde -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E3A5F"
            android:padding="20dp"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Solde actuel"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textViewSolde"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 FCFA"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Revenus / Dépenses -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Revenus"
                    android:textColor="#2E7D32"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/textViewRevenus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 FCFA"
                    android:textColor="#2E7D32"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dépenses"
                    android:textColor="#C62828"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/textViewDepenses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 FCFA"
                    android:textColor="#C62828"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Budget -->
        <TextView
            android:id="@+id/textViewBudgetLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Budget du mois"
            android:textColor="#1E3A5F"
            android:textSize="14sp"
            android:layout_marginTop="20dp" />

        <ProgressBar
            android:id="@+id/progressBarBudget"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/textViewBudgetDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aucun budget défini pour ce mois"
            android:textColor="#666666"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <!-- Dernières transactions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dernières transactions"
            android:textColor="#1E3A5F"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:id="@+id/layoutTransactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Se déconnecter"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:layout_marginTop="32dp" />
        <Button
            android:id="@+id/buttonSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paramètres"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>