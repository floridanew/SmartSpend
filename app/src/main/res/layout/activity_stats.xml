<?xml version="1.0" encoding="utf-8"?>
<!--
  Écran Statistiques (Membre 5).
  Structure : un LinearLayout vertical qui contient
    - une zone défilante (ScrollView) avec le résumé + les 2 graphiques
    - une barre de navigation (BottomNavigationView) fixée en bas
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gris_fond">

    <!-- Zone qui défile (poids 1 = prend toute la place au-dessus de la barre) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Titre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Statistiques"
                android:textColor="@color/bleu_fonce"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- ====================  RÉSUMÉ TEXTUEL  ==================== -->

            <!-- Solde net (carte mise en avant) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bleu_fonce"
                android:padding="20dp"
                android:layout_marginTop="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solde net"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/textViewSoldeNet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 FCFA"
                    android:textColor="@color/white"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Revenus / Dépenses côte à côte -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/white"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Revenus du mois"
                        android:textColor="@color/vert_revenu"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/textViewRevenus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 FCFA"
                        android:textColor="@color/vert_revenu"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/white"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dépenses du mois"
                        android:textColor="@color/rouge_depense"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/textViewDepenses"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 FCFA"
                        android:textColor="@color/rouge_depense"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Taux d'épargne + catégorie la plus dépensière -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/textViewTauxEpargne"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Taux d'épargne : 0 %"
                    android:textColor="@color/bleu_fonce"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textViewMoyenne"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dépense moyenne : 0 FCFA"
                    android:textColor="@color/gris_texte"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/textViewCategorieMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catégorie la plus dépensière : -"
                    android:textColor="@color/gris_texte"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- ====================  GRAPHIQUE CIRCULAIRE  ==================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dépenses par catégorie"
                android:textColor="@color/bleu_fonce"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="8dp"
                android:background="@color/white"
                android:padding="8dp" />

            <!-- ====================  GRAPHIQUE EN BARRES  ==================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Revenus vs Dépenses par mois"
                android:textColor="@color/bleu_fonce"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/white"
                android:padding="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ====================  BARRE DE NAVIGATION  ==================== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:itemIconTint="@color/bleu_fonce"
        app:itemTextColor="@color/bleu_fonce"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
